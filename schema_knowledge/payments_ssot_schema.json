  "table_type": "TABLE",
  "table_description": "Single Source of Truth (SSOT) for all BukuWarung payment transactions. Consolidates Payment In, Payment Out, PPOB, QRIS, QRIS-Retail, and SALDO. Each row = one payment attempt (bw_order_id). product_type determines populated columns; status_v2 encodes full lifecycle; transaction_date (WIB) is partition key.",
  "table_description_source": "bigquery_table_description",
  "table_description_auto_generated": false,
  "is_derived": true,
  "creation_query": {
    "creation_time": "2026-05-05 08:00:07.517000+00:00",
    "statement_type": "CREATE_TABLE_AS_SELECT",
    "query": "\n    -- EDC Active User (At least 1x attempt) since beginning (Aug \u201823)\n-- EDC Purchaser (At least bought 1 device) since beginning (Aug \u201823)\n-- Core Payment User since Payment reopening (Aug \u201822)\n-- PPOB User since Payment reopening (Aug \u201822)\n-- Merchants Visited by Sales team since EDC launched (Aug \u201823)\n\n\nCREATE OR REPLACE TABLE `ledger-fcc1e.temp_amal.gmap_static_input`  AS\nWITH cp AS (\n    SELECT DISTINCT \n        user_id AS bw_user_id\n        , 1 AS FLAG\n    FROM `payment_reports.payments_ssot` \n    WHERE \n      1 = 1\n      AND transaction_status='COMPLETED'\n      AND product_type IN (\n          \"Payment Out\"\n          , \"Payment In\"\n          -- , \"QRIS\", \"SALDO\"\n          -- , \"PPOB\"\n          )\n      AND refunded_ts IS NULL\n      AND transaction_date BETWEEN CURRENT_DATE() - 30 AND CURRENT_DATE() - 1\n)\n\n, ppob AS (\n    SELECT DISTINCT \n        user_id AS bw_user_id\n        , 1 AS FLAG\n    FROM `payment_reports.payments_ssot`\n    WHERE \n      1 = 1\n      AND transaction_status="
  },
  "transformation_type": {
    "type": "derived",
    "transformation": [
      "date_transformation"
    ],
